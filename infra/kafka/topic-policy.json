{
  "defaults": {
    "partitions": 3,
    "replicationFactor": 1,
    "cleanupPolicy": "delete",
    "retentionMs": 604800000,
    "segmentMs": 3600000,
    "minInSyncReplicas": 1
  },
  "topics": {
    "ride.created": { "partitions": 6 },
    "ride.assigned": { "partitions": 6 },
    "ride.cancelled": { "partitions": 6 },
    "payment.completed": { "partitions": 6 },
    "payment.failed": { "partitions": 6 },
    "review.created": { "partitions": 3 },
    "driver.location.updated": { "partitions": 12 }
  },
  "retry": {
    "enabled": true,
    "tiers": [
      { "suffix": "retry.30s", "retentionMs": 1800000 },
      { "suffix": "retry.5m", "retentionMs": 21600000 },
      { "suffix": "retry.30m", "retentionMs": 259200000 }
    ]
  },
  "dlq": {
    "enabled": true,
    "retentionMs": 1209600000
  }
}
