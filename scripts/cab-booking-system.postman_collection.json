{
  "info": {
    "name": "cab-booking-system (Gateway)",
    "_postman_id": "7b2b9e4b-4d4b-4a4c-8f77-0a7d2b8b1a11",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user1@test.com\",\n  \"password\": \"secret123\",\n  \"role\": \"user\"\n}"
        },
        "url": "{{baseUrl}}/v1/auth/register"
      }
    },
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200 || pm.response.code === 201) {",
              "  const data = pm.response.json();",
              "  if (data.tokens && data.tokens.accessToken) {",
              "    pm.environment.set('token', data.tokens.accessToken);",
              "    pm.environment.set('refreshToken', data.tokens.refreshToken);",
              "  }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"identifier\": \"user1@test.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": "{{baseUrl}}/v1/auth/login"
      }
    },
    {
      "name": "Auth - Refresh",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/v1/auth/refresh"
      }
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": "{{baseUrl}}/v1/auth/logout"
      }
    },
    {
      "name": "Auth - Verify",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/v1/auth/verify"
      }
    },
    {
      "name": "Ride - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Idempotency-Key", "value": "ride-{{timestamp}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pickupLat\": 10.1,\n  \"pickupLng\": 20.2\n}"
        },
        "url": "{{baseUrl}}/v1/rides"
      }
    },
    {
      "name": "Ride - List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/v1/rides"
      }
    },
    {
      "name": "Ride - Get by Id",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/v1/rides/{{rideId}}"
      }
    },
    {
      "name": "Review - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Idempotency-Key", "value": "review-{{timestamp}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rideId\": \"{{rideId}}\",\n  \"driverId\": \"11111111-1111-1111-1111-111111111111\",\n  \"rating\": 5,\n  \"comment\": \"great\"\n}"
        },
        "url": "{{baseUrl}}/v1/reviews"
      }
    },
    {
      "name": "Review - List",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/v1/reviews"
      }
    },
    {
      "name": "Review - Get by Id",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/v1/reviews/{{reviewId}}"
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "rideId", "value": "" },
    { "key": "reviewId", "value": "" },
    { "key": "timestamp", "value": "{{{{$timestamp}}}}" }
  ]
}
