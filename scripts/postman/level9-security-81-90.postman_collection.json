      "name": "Case 90 - Sensitive Data Masking",
      "item": [
        {
          "name": "90A Invalid Token Users API",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer fake.jwt.token"
              }
            ],
            "url": "{{baseUrl}}/v1/users?limit=1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Invalid token is rejected', function () { pm.expect([401, 403]).to.include(pm.response.code); });",
                  "pm.test('No sensitive leak', function () { pm.expect(pm.response.text()).to.not.match(/password_hash|api[_-]?key|jwt[_-]?secret|SQLSTATE|Sequelize|private key/i); });"
                ]
              }
            }
          ]
        },
        {
          "name": "90B Payment With Card-Like Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "c90-{{uniq}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"rideId\":\"ride_sensitive_test_{{uniq}}\",\"amount\":\"100000\",\"currency\":\"VND\",\"note\":\"card={{rawCard}}\"}"
            },
            "url": "{{baseUrl}}/v1/payments"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Response does not expose full card number', function () {",
                  "  pm.expect(pm.response.text()).to.not.include(pm.collectionVariables.get('rawCard'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "90C Unknown Route",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/nonexistent-domain/anything"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Unknown route returns 404', function () { pm.response.to.have.status(404); });",
                  "pm.test('No sensitive leak', function () { pm.expect(pm.response.text()).to.not.match(/password_hash|api[_-]?key|jwt[_-]?secret|SQLSTATE|Sequelize|private key/i); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
