    {
      "name": "Case 83 - JWT Tampering",
      "item": [
        {
          "name": "83A Bad Signature Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}x"
              }
            ],
            "url": "{{baseUrl}}/v1/users?limit=1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Bad signature is rejected', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        },
        {
          "name": "83B Role Escalation Tampered Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function b64urlDecode(input) {",
                  "  input = input.replace(/-/g, '+').replace(/_/g, '/');",
                  "  while (input.length % 4) input += '=';",
                  "  return atob(input);",
                  "}",
                  "function b64urlEncode(input) {",
                  "  return btoa(input).replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/g, '');",
                  "}",
                  "const token = pm.collectionVariables.get('userToken') || '';",
                  "const parts = token.split('.');",
                  "if (parts.length === 3) {",
                  "  const payload = JSON.parse(b64urlDecode(parts[1]));",
                  "  payload.role = 'admin';",
                  "  payload.roles = ['admin'];",
                  "  pm.collectionVariables.set('tamperedRoleToken', parts[0] + '.' + b64urlEncode(JSON.stringify(payload)) + '.' + parts[2]);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Tampered role token is rejected', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{tamperedRoleToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/users?limit=1"
          }
        },
        {
          "name": "83C Malformed Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer abc.def"
              }
            ],
            "url": "{{baseUrl}}/v1/users?limit=1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Malformed token is rejected', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    },
