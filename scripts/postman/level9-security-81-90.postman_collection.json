    {
      "name": "Case 85 - Rate Limit Attack",
      "description": "Postman cannot reproduce the script's Node.js concurrency exactly. Run this request in Collection Runner with many iterations to observe 429 responses, or use the original shell script for the authoritative burst test.",
      "item": [
        {
          "name": "85 Booking Spam Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-load-test",
                "value": "security-rate-limit"
              },
              {
                "key": "Idempotency-Key",
                "value": "c85-{{$timestamp}}-{{$randomInt}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"pickup\":{\"lat\":10.7601,\"lng\":106.6601},\"drop\":{\"lat\":10.7701,\"lng\":106.7001},\"vehicle_type\":\"CAR\",\"distance_km\":5,\"traffic_level\":0.5}"
            },
            "url": "{{baseUrl}}/v1/bookings"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Request does not collapse backend', function () {",
                  "  pm.expect(pm.response.code).to.not.be.within(500, 599);",
                  "});",
                  "pm.test('Rate limit is acceptable if 429 appears during runner burst', function () {",
                  "  pm.expect([200, 201, 400, 422, 429]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
