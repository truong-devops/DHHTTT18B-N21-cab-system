    {
      "name": "Case 81 - SQL Injection Attempt",
      "item": [
        {
          "name": "81A Login SQL Injection",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"' OR 1=1 --\",\"password\":\"anything\"}"
            },
            "url": "{{baseUrl}}/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Injection login is rejected', function () {",
                  "  pm.expect([400, 401]).to.include(pm.response.code);",
                  "});",
                  "pm.test('No sensitive error leak', function () {",
                  "  pm.expect(pm.response.text()).to.not.match(/password_hash|api[_-]?key|jwt[_-]?secret|SQLSTATE|Sequelize|syntax error|stack|private key/i);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "81B Users Query SQL Injection",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/users?email=%27%20OR%20%271%27=%271"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('SQL injection query is not accepted as valid success', function () {",
                  "  pm.expect([200, 201]).to.not.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
