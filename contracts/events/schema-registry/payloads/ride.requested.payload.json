{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cab-booking.local/schemas/events/payloads/ride.requested",
  "title": "ride.requested.payload",
  "type": "object",
  "required": [
    "event_type",
    "ride_id",
    "booking_id",
    "user_id",
    "pickup",
    "drop",
    "distance_km",
    "eta_minutes",
    "timestamp"
  ],
  "properties": {
    "event_type": { "const": "ride_requested" },
    "ride_id": { "type": "string", "minLength": 1 },
    "booking_id": { "type": "string", "minLength": 1 },
    "user_id": { "type": "string", "minLength": 1 },
    "pickup": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "additionalProperties": false
    },
    "drop": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "additionalProperties": false
    },
    "distance_km": { "type": "number", "minimum": 0 },
    "eta_minutes": { "type": "integer", "minimum": 0 },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
