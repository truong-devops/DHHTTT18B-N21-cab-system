{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cab-booking.local/schemas/events/payloads/ride.accepted",
  "title": "ride.accepted.payload",
  "type": "object",
  "required": ["event_type", "booking_id", "ride_id", "driver_id", "status", "timestamp"],
  "properties": {
    "event_type": { "const": "ride_accepted" },
    "booking_id": { "type": "string", "minLength": 1 },
    "ride_id": { "type": "string", "minLength": 1 },
    "driver_id": { "type": "string", "minLength": 1 },
    "status": { "const": "ACCEPTED" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
