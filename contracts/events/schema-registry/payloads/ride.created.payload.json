{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cab-booking.local/schemas/events/payloads/ride.created",
  "title": "ride.created.payload",
  "type": "object",
  "required": ["rideId", "pickup", "timestamp"],
  "properties": {
    "rideId": { "type": "string", "minLength": 1 },
    "bookingId": { "type": "string" },
    "riderId": { "type": "string", "pattern": "^[0-9]{8}$" },
    "pickup": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "address": { "type": "string" }
      },
      "additionalProperties": false
    },
    "dropoff": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "address": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pricing": {
      "type": "object",
      "required": ["estimatedFare", "currency"],
      "properties": {
        "estimatedFare": { "type": "number" },
        "currency": { "type": "string", "minLength": 3, "maxLength": 3 }
      },
      "additionalProperties": false
    },
    "vehicleType": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
