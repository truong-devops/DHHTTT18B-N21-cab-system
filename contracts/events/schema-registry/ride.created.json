{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RideCreated",
  "type": "object",
  "required": ["eventId", "type", "rideId", "pickup", "timestamp"],
  "properties": {
    "eventId": { "type": "string" },
    "type": { "const": "RideCreated" },
    "rideId": { "type": "string" },
    "pickup": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      }
    },
    "timestamp": { "type": "string" }
  }
}
