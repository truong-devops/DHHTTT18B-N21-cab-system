{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReviewCreated",
  "type": "object",
  "required": ["eventId", "type", "reviewId", "rideId", "rating", "createdAt"],
  "properties": {
    "eventId": { "type": "string" },
    "type": { "const": "ReviewCreated" },
    "reviewId": { "type": "string" },
    "rideId": { "type": "string" },
    "riderId": { "type": "string" },
    "driverId": { "type": "string" },
    "rating": { "type": "number" },
    "comment": { "type": "string" },
    "status": { "type": "string" },
    "createdAt": { "type": "string" }
  }
}
