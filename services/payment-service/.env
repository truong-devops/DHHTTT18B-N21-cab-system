NODE_ENV=development
SERVICE_NAME=payment-service
PORT=3007

# Database (prefer DATABASE_URL)
DATABASE_URL=postgres://cab:cabpass@localhost:5432/payment-service_db?sslmode=disable
PGHOST=localhost
PGPORT=5432
PGUSER=cab
PGPASSWORD=cabpass
PGDATABASE=payment-service_db
PGPOOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:29092
KAFKA_CONSUME_TOPICS=ride.created,ride.assigned,ride.cancelled
KAFKA_CLIENT_ID=payment-service
KAFKA_CONSUMER_GROUP_ID=payment-service-group
OUTBOX_PUBLISH_INTERVAL_MS=5000

# Auth
JWT_ACCESS_SECRET=dev-secret
JWT_SECRET=dev-secret

# Logging
LOG_LEVEL=info

# Idempotency
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_LOCK_TTL_MS=15000

# VietQR
VIETQR_API_URL=https://api.vietqr.io/v2/generate
VIETQR_BANK_BIN=970422
VIETQR_ACCOUNT_NUMBER=0869500573
VIETQR_ACCOUNT_NAME=VO VAN TU TAI
VIETQR_MERCHANT_CITY=HO CHI MINH
VIETQR_FORMAT=text
VIETQR_CLIENT_ID=
VIETQR_API_KEY=
VIETQR_EXPIRES_IN_MINUTES=15

# PayOS
PAYOS_API_URL=https://api-merchant.payos.vn
PAYOS_CLIENT_ID=0cd4e2ea-810f-4e2c-8627-484eae921c0f
PAYOS_API_KEY=ea8041b5-2a2a-494d-9d79-906ca0b86815
PAYOS_CHECKSUM_KEY=00a46f57f4467adc411e2f61eaf3be12f4291d26c67aeede17548c050d6ff8fe
PAYOS_PARTNER_CODE=
PAYOS_RETURN_URL=http://localhost:5173/admin/payments?payos=success
PAYOS_CANCEL_URL=http://localhost:5173/admin/payments?payos=cancel
PAYOS_QR_SOURCE=VIETQR
PAYOS_AUTO_SYNC_ENABLED=true
PAYOS_AUTO_SYNC_INTERVAL_MS=15000
PAYOS_AUTO_SYNC_BATCH_SIZE=20
