{
  "name": "cab-booking-system",
  "private": true,
  "workspaces": [
    "libs/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "dev:infra": "docker compose --env-file .env -f infra/docker-compose.dev.yml up -d",
    "dev:observability": "docker compose --env-file .env -f infra/docker-compose.dev.yml -f infra/observability/docker-compose.observability.yml up -d elasticsearch logstash kibana otel-collector prometheus tempo grafana && docker compose --env-file .env -f infra/docker-compose.dev.yml -f infra/observability/docker-compose.observability.yml up -d",
    "down:infra": "docker compose --env-file .env -f infra/docker-compose.dev.yml down -v",
    "down:observability": "docker compose --env-file .env -f infra/docker-compose.dev.yml -f infra/observability/docker-compose.observability.yml down -v",
    "logs:kafka": "docker compose --env-file .env -f infra/docker-compose.dev.yml logs -f kafka",
    "health": "node scripts/healthcheck.js",
    "seed:all": "node scripts/seed-all.js",
    "generate:payment-types": "openapi-typescript contracts/openapi/payment-service.yaml -o libs/types/src/payment-service.ts"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
